# Docker Compose production ingress. Keep the origin on loopback when Cloudflare
# Tunnel is used; use 0.0.0.0 only for an explicitly approved direct-host fallback.
HOST_BIND_ADDRESS=127.0.0.1
# Use one free port from 18080-18999.
HOST_PORT=18080
COMPOSE_PROJECT_NAME=overnight-web-agent-kit

# Frontend uses HTTP through the same-origin Caddy route in production.
NEXT_PUBLIC_DATA_SOURCE=http
NEXT_API_ORIGIN=http://api:8000

# Cloudflare Tunnel is optional. Create a remotely managed tunnel and keep its
# token only in an untracked .env file or a secret manager; never commit it.
CLOUDFLARE_TUNNEL_TOKEN=
